{
  "name": "quran-hajrah-smart-platform",
  "version": "22.0.0",
  "private": true,
  "type": "module",
  "description": "Quran Hajrah Smart Platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n admin,portal,api -c cyan,green,yellow \"npm run dev -w @quran-hajrah/admin\" \"npm run dev -w @quran-hajrah/portal\" \"npm run dev -w @quran-hajrah/api\"",
    "build": "npm run build --workspaces --if-present",
    "postinstall": "node tooling/generate-prisma.mjs",
    "build:artifacts": "npm run db:generate && npm run build -w @quran-hajrah/database && npm run build -w @quran-hajrah/shared && npm run build -w @quran-hajrah/auth && npm run build -w @quran-hajrah/ui && npm run build -w @quran-hajrah/api && npm run build -w @quran-hajrah/admin && npm run build -w @quran-hajrah/portal && npm run validate:production-startup",
    "build:production": "npm ci --include=dev && npm run build:artifacts",
    "postbuild:production": "npm run db:deploy",
    "build:hostinger": "npm run build:production",
    "deploy:production": "npm run start:production",
    "prestart:production": "npm run db:deploy",
    "start:production": "node apps/api/dist/server.js",
    "validate:production-startup": "node tooling/validate-production-startup.mjs",
    "smoke:production": "node tooling/production-smoke.mjs",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint apps packages --ext .js,.cjs,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:check": "node tooling/check-sensitive-files.mjs",
    "typecheck": "npm run db:generate && npm run build -w @quran-hajrah/database && npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate -w @quran-hajrah/database",
    "db:validate": "npm run validate -w @quran-hajrah/database",
    "db:migrate": "npm run migrate:dev -w @quran-hajrah/database",
    "db:deploy": "npx prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:status": "npm run migrate:status -w @quran-hajrah/database",
    "db:diagnostics": "npm run diagnostics -w @quran-hajrah/database",
    "db:studio": "npm run studio -w @quran-hajrah/database",
    "db:seed": "npm run seed -w @quran-hajrah/database",
    "create:admin": "node packages/database/dist/create-admin.js",
    "create:admin:dev": "npm run create:admin:dev -w @quran-hajrah/database"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "prisma": "^6.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
