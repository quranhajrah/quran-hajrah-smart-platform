{
  "name": "@quran-hajrah/database",
  "version": "22.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "validate": "prisma validate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "diagnostics": "tsx src/diagnostics.ts",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "create:admin": "node dist/create-admin.js",
    "create:admin:dev": "tsx src/create-admin.ts",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
